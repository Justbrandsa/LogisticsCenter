{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "includeFiles": "data/route-ledger.sqlite*"
    }
  },
  "crons": [
    {
      "path": "/api/jobs/order-delete-log-email",
      "schedule": "*/10 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?route=:path*"
    }
  ]
}
