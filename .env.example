# Copy this file to .env.local for local development.
# Keep real secrets out of GitHub; configure production secrets in Vercel.

# Turso Cloud durable database
TURSO_DATABASE_URL=libsql://your-database-name.aws-region.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-auth-token

# Production safety
LOGISTICS_REQUIRE_PERSISTENT_STORAGE=true
LOGISTICS_ALLOW_TEMPORARY_STORAGE=false
CRON_SECRET=replace-with-a-long-random-value

# Optional local SQLite overrides
# LOGISTICS_DB_PATH=C:\absolute\path\to\route-ledger.sqlite
# LOGISTICS_DATA_DIR=C:\absolute\path\to\durable\data

# Mail sender identity and routing
MAIL_FROM=artwork3@giftwrap.co.za
MAIL_FROM_NAME=Logistics Centre
MAIL_TO=admin3@giftwrap.co.za
MAIL_ADMIN_ACTION_TO=admin3@giftwrap.co.za
MAIL_ROLLOVER_TEST_TO=artwork3@giftwrap.co.za
MAIL_DROPPED_OFFICE_SS_TO=Sheryl-ann@giftwrap.co.za
MAIL_DROPPED_OFFICE_SB_TO=reception@giftwrap.co.za
MAIL_DROPPED_OFFICE_MOR_MAR_TO=promo22@giftwrap.co.za
MAIL_DROPPED_OFFICE_ORDER_TO=orders@giftwrapshop.co.za
MAIL_DROPPED_OFFICE_FALLBACK_TO=order@giftwrapshop.co.za

# Microsoft Graph mail credentials
MAIL_TENANT_ID=replace-with-azure-tenant-id
MAIL_CLIENT_ID=replace-with-azure-client-id
MAIL_CLIENT_SECRET=replace-with-azure-client-secret-value
